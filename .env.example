# ── TradeSignal AI — Environment Variables ──────────────────

# Required: Gemini AI Key
GEMINI_API_KEY=your_gemini_api_key_here

# Required for Forex data (get free key at twelvedata.com)
TWELVE_DATA_KEY=your_twelve_data_key_here

# Optional: Telegram Bot (for auto-alerts)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL=@your_channel_or_chat_id

# Server port (default: 3000)
PORT=3000
